#################################
### Elysium's Hyprland config ###
#################################

source= ~/.config/hypr/modules/*

debug {
  disable_logs = false
  damage_tracking = 2
}

################
### MONITORS ###
################

monitorv2 {
  # desktop
  output = DP-3
  mode = 1920x1080@144
  position = 0x0
  scale = 1
}

xwayland {
  force_zero_scaling = true
}

#####################
### LOOK AND FEEL ###
#####################

general {
    gaps_in = 4
    gaps_out = 6
    border_size = 2
    resize_on_border = false
    col.active_border = rgb(d4c5b0) rgb(A08EC4) 45deg
    col.inactive_border = rgb(2A2D35)
    allow_tearing = true
    layout = dwindle
}

render {
  cm_auto_hdr = 0
}

decoration {
    rounding = 10
    rounding_power = 2
    active_opacity = 1.0
    inactive_opacity = 0.8
    fullscreen_opacity = 1.0
    shadow {
        enabled = true
        range = 50
        offset = 0 4
        render_power = 10
        color = rgba(19, 21, 26, 136)
    }
  blur {
        enabled = true
        xray = true
        special = false
        new_optimizations = true
        size = 10
        passes = 3
        brightness = 1
        noise = 0.05
        contrast = 0.89
        vibrancy = 0.5
        vibrancy_darkness = 0.5
        popups = false
        popups_ignorealpha = 0.6
        input_methods = true
        input_methods_ignorealpha = 0.8
    }
}

animations {
    enabled = true
    # Curves
    bezier = expressiveFastSpatial, 0.42, 1.67, 0.21, 0.90
    bezier = expressiveSlowSpatial, 0.39, 1.29, 0.35, 0.98
    bezier = expressiveDefaultSpatial, 0.38, 1.21, 0.22, 1.00
    bezier = expressiveOvershoot, 0.05, 0.9, 0.1, 1.1
    bezier = emphasizedDecel, 0.05, 0.7, 0.1, 1
    bezier = emphasizedAccel, 0.3, 0, 0.8, 0.15
    bezier = standardDecel, 0, 0, 0, 1
    bezier = menu_decel, 0.1, 1, 0, 1
    bezier = menu_accel, 0.52, 0.03, 0.72, 0.08
    bezier = stall, 1, -0.1, 0.7, 0.85
    # Configs
    # windows
    animation = windowsIn, 1, 2.5, expressiveDefaultSpatial, popin 85%
    animation = fadeIn, 1, 2.5, expressiveDefaultSpatial
    animation = windowsOut, 1, 1.8, emphasizedDecel, popin 90%
    animation = fadeOut, 1, 1.8, menu_decel
    animation = windowsMove, 1, 2.5, expressiveDefaultSpatial, slide
    animation = border, 1, 4, emphasizedDecel
    # layers
    animation = layersIn, 1, 1.5, menu_decel, popin 90%
    animation = layersOut, 1, 1.8, menu_accel, popin 94%
    # fade
    animation = fadeLayersIn, 1, 0.4, menu_decel
    animation = fadeLayersOut, 1, 2, stall
    # workspaces
    animation = workspaces, 1, 4.5, expressiveDefaultSpatial, slide fade
    ## specialWorkspace
    animation = specialWorkspaceIn, 1, 2.2, expressiveDefaultSpatial, slidevert popin 85%
    animation = specialWorkspaceOut, 1, 1, emphasizedAccel, slidevert
    # zoom
    animation = zoomFactor, 1, 2.5, standardDecel
}

dwindle {
    preserve_split = true # You probably want this
    smart_split = false
    smart_resizing = false
}

master {
  new_status = slave
  #master_ratio = .75
  #master_side = left
}

misc {
    disable_hyprland_logo = true
    disable_splash_rendering = true
    vrr = 0
    mouse_move_enables_dpms = true
    key_press_enables_dpms = true
    animate_manual_resizes = false
    animate_mouse_windowdragging = false
    enable_swallow = false
    swallow_regex = (foot|kitty|allacritty|Alacritty)
    on_focus_under_fullscreen = 2
    allow_session_lock_restore = true
    session_lock_xray = true
    initial_workspace_tracking = false
    focus_on_activate = true
    render_unfocused_fps = 30
}

