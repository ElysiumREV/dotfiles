{
  "spacing": 2,
  "modules-left": ["cpu", "temperature", "memory", "mpd"],
  "modules-center": ["hyprland/workspaces"],
  "modules-right": [
    "tray",
    "pulseaudio",
    "backlight",
    "battery",
    "clock"
  ],
  "hyprland/workspaces": {
    "format": "{icon}",
    "on-click": "activate",
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
    "all-outputs": true,
    "active-only": false,
    "show-special": false,
    "persistent-only": false,
    "format-icons": {
        "1": "I",
        "2": "II",
        "3": "III",
        "4": "IV",
        "5": "V",
        "6": "VI",
        "7": "VII",
        "8": "VIII",
        "9": "IX",
        "10": "X"
    },
    "sort-by-number": true
  },
  "mpd": {
    "format": "{stateIcon} {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}{artist} - {album} - {title}",
    "format-disconnected": "Disconnected",
    "format-stopped": "{consumeIcon}{randomIcon}{repeatIcon}{singleIcon}Stopped",
    "interval": 10,
    "consume-icons": {
        "on": "пГД "
    },
    "random-icons": {
        "off": "<span color=\"#f53c3c\">пБі</span> ",
        "on": "пБі "
    },
    "repeat-icons": {
        "on": "пАЮ "
    },
    "single-icons": {
        "on": "пАЮ1 "
    },
    "state-icons": {
        "paused": "пБМ",
        "playing": "пАБ"
    },
    "tooltip-format": "MPD (connected)",
    "tooltip-format-disconnected": "MPD (disconnected)"
},
  "tray": {
    "icon-size": 16,
    "spacing": 6
  },
  "clock": {
    "interval": 60,
    "format": "{:%d %b %H:%M}",
    "smooth-scrolling-threshold": 4,
    "tooltip": true,
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
  },
  "cpu": {
    "format": "пЛЫ {usage}%",
    "tooltip": true,
    "interval": 5
  },
  "memory": {
    "format": "пГЙ {}%",
    "interval": 5
  },
  "temperature": {
    "critical-threshold": 80,
    "format": "{icon}{temperatureC}¬∞C",
    "format-icons": ["пЛЛ", "пЛЙ", "пЛЗ"],
    "hwmon-path": "/sys/class/hwmon/hwmon4/temp1_input"
  },
  "backlight": {
    "format": "{percent}% {icon}",
    "format-icons": ["оОН ", "оПУ ", "оПС ", "оПП ", "оПО ", "оПН ", "оПК ", "оПИ ", "оОЫ "]
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{capacity}% {icon}",
    "format-full": "{capacity}% {icon}",
    "format-charging": "{capacity}% у∞ВД ",
    "format-plugged": "{capacity}% пЗ¶ ",
    "format-alt": "{time} {icon}",
    "format-icons": ["пЙД ", "пЙГ ", "пЙВ ", "пЙБ ", "пЙА "],
    "interval": 5
  },
  "battery#bat2": {
    "bat": "BAT2"
  },
  "pulseaudio": {
  "format": "{volume}% {icon}",
  "format-bluetooth": "{volume}%{icon}пКФ",
  "format-bluetooth-muted": "ої® {icon}пКФ",
  "format-muted": "ої® ",
  "format-icons": {
    "default": ["пА¶ ", "пАІ ", "пА® "]
  },
  "on-click": "pavucontrol",
  "tooltip": true,
  "tooltip-format": "{volume}% {icon} {format_source} пД∞",
  "interval": 5
}
}
